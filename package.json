{
  "name": "remempalace",
  "version": "0.1.0",
  "description": "Full-lifecycle memory plugin for OpenClaw, powered by MemPalace.",
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist", "openclaw.plugin.json"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": ["./dist/index.js"]
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "lru-cache": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/derekmensch-alt/remempalace.git"
  }
}
